## =============================================================================
## Palworld Proton Server — Environment Configuration
## Copy to .env and adjust:  cp .env.example .env
## All gameplay rate vars are optional — leave blank to use ini defaults.
## =============================================================================

## ---- Server Identity (applied to PalWorldSettings.ini) ----------------------
SERVER_NAME=My Palworld Server
SERVER_DESCRIPTION=
SERVER_PASSWORD=
ADMIN_PASSWORD=changeme
MAX_PLAYERS=32

## ---- Network ----------------------------------------------------------------
PORT=8211
QUERY_PORT=27015
PUBLIC_IP=
PUBLIC_PORT=
RCON_ENABLED=true
RCON_PORT=25575
REST_API_ENABLED=false
REST_API_PORT=8212

## ---- Crossplay (Palworld 1.0) -----------------------------------------------
## Which platforms can connect. All = full crossplay (Steam, Xbox, PS5, Mac)
## Remove platforms to restrict access
CROSSPLAY_PLATFORMS=Steam,Xbox,PS5,Mac

## ---- PvP (Palworld 1.0 — trial feature) -------------------------------------
## Enable PvP mode. Requires all three toggles: bIsPvP, bEnablePlayerToPlayerDamage,
## bEnableDefenseOtherGuildPlayer. The entrypoint sets all three when ENABLE_PVP=true.
ENABLE_PVP=false

## ---- Gameplay (CLI args) ----------------------------------------------------
## Community=true makes the server show in the community browser (use with SERVER_PASSWORD)
## Multithreading=true enables -useperfthreads -NoAsyncLoadingThread -UseMultithreadForDS
COMMUNITY=false
MULTITHREADING=true

## ---- Gameplay (PalWorldSettings.ini — general) -----------------------------
## Difficulty: None (custom rates), Casual, Normal, Hard
## DeathPenalty: None, Item, ItemAndEquipment, All
## ENABLE_INVADER_ENEMY: false halves RAM usage (disables base raids)
DIFFICULTY=
DEATH_PENALTY=
ENABLE_INVADER_ENEMY=

## ---- Gameplay (PalWorldSettings.ini — rates) --------------------------------
## All rates: 1.0 = vanilla. Leave blank to use ini defaults.
## Note: "Decreace" spelling is Pocketpair's typo — must match exactly.
EXP_RATE=
PAL_CAPTURE_RATE=
PAL_SPAWN_NUM_RATE=
PAL_EGG_HATCHING_TIME=
WORK_SPEED_RATE=
DAYTIME_SPEED_RATE=
NIGHTTIME_SPEED_RATE=
COLLECTION_DROP_RATE=
ENEMY_DROP_ITEM_RATE=

## ---- Gameplay (PalWorldSettings.ini — Pal/player stats) --------------------
PAL_STOMACH_DECREACE_RATE=
PAL_STAMINA_DECREACE_RATE=
PLAYER_STOMACH_DECREACE_RATE=
PLAYER_STAMINA_DECREACE_RATE=
PAL_DAMAGE_RATE_ATTACK=
PAL_DAMAGE_RATE_DEFENSE=
PLAYER_DAMAGE_RATE_ATTACK=
PLAYER_DAMAGE_RATE_DEFENSE=

## ---- Base/Guild Limits ------------------------------------------------------
BASE_CAMP_MAX_NUM=
BASE_CAMP_WORKER_MAX_NUM=
GUILD_PLAYER_MAX_NUM=
DROP_ITEM_MAX_NUM=

## ---- Mods -------------------------------------------------------------------
## UE4SS enables Lua/DLL server-side mods (requires Windows server via Proton)
## WARNING: Palworld 1.0 recompiles the executable — old mods WILL break.
## Delete old mod files (don't just disable) before updating to 1.0.
## Check each mod's page for explicit 1.0 compatibility before re-enabling.
ENABLE_UE4SS=true

## ---- Version Pinning --------------------------------------------------------
## Lock the server to a specific Steam manifest ID to prevent game updates from
## breaking UE4SS mods. Find manifest IDs on SteamDB (app 2394010).
## Leave blank to always get the latest version.
TARGET_MANIFEST_ID=

## ---- Backups ----------------------------------------------------------------
## BACKUP_ENABLED=true starts supercronic with a scheduled backup job
## Backups are saved to game/backups/ inside the volume
## Cron expression format: https://crontab-generator.org
BACKUP_ENABLED=false
BACKUP_CRON_EXPRESSION=0 0 * * *
DELETE_OLD_BACKUPS=false
BACKUP_RETENTION_DAYS=30

## ---- Maintenance ------------------------------------------------------------
## Set to true to run SteamCMD validation on every container start
## Recommended for the first run after Palworld 1.0 update
ALWAYS_UPDATE_ON_START=false
TZ=UTC

## ---- Resource Limits (uncomment in docker-compose.yml if needed) -----------
## Palworld 1.0 roughly doubles the map — plan for more RAM than early access
## Small server (1-8 players): 16GB minimum
## Community server (8-32 players): 32GB recommended
## mem_limit: 16g  # Adjust for your player count

## ---- Advanced (rarely changed) ---------------------------------------------
## Proton version (must match a GE-Proton release tag from github.com/GloriousEggroll/proton-ge-custom)
## Latest stable: GE-Proton10-26 | Latest overall: GE-Proton11-1 (Proton 11 rebase, test before production)
# PROTON_VERSION=GE-Proton10-26
